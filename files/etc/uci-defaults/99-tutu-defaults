#!/bin/sh
# 99-tutu-defaults — 首次启动自动执行，配置完成后自动删除

# ============================================================
# 密码
# ============================================================
passwd -d root

# ============================================================
# Hostname
# ============================================================
uci set system.@system[0].hostname='TUTU-GW'
uci commit system

# ============================================================
# LAN — 192.168.5.1 / 255.255.255.0
# ============================================================
uci set network.lan.ipaddr='192.168.5.1'
uci set network.lan.netmask='255.255.255.0'
uci del network.lan.ip6assign 2>/dev/null

# ============================================================
# br-lan bridge — eth0 eth1 eth2 eth3
# ============================================================
# 遍历所有 device section，找到 name=br-lan 的那个
BR_SECTION=''
for section in $(uci show network | grep -E "=device$" | sed 's/network\.\([^=]*\)=device/\1/'); do
    if [ "$(uci -q get network."${section}".name)" = 'br-lan' ]; then
        BR_SECTION="$section"
        break
    fi
done

if [ -n "$BR_SECTION" ]; then
    uci del network."${BR_SECTION}".ports 2>/dev/null
    uci add_list network."${BR_SECTION}".ports='eth0'
    uci add_list network."${BR_SECTION}".ports='eth1'
    uci add_list network."${BR_SECTION}".ports='eth2'
    uci add_list network."${BR_SECTION}".ports='eth3'
else
    # 找不到就新建一个有名 section
    uci set network.brlan=device
    uci set network.brlan.name='br-lan'
    uci set network.brlan.type='bridge'
    uci add_list network.brlan.ports='eth0'
    uci add_list network.brlan.ports='eth1'
    uci add_list network.brlan.ports='eth2'
    uci add_list network.brlan.ports='eth3'
fi

# ============================================================
# WAN — PPPoE / eth4.3961 (VLAN 3961)
# ============================================================
uci set network.wan.proto='pppoe'
uci set network.wan.device='eth4.3961'
uci del network.wan.username 2>/dev/null
uci del network.wan.password 2>/dev/null

# 禁用 wan6
uci set network.wan6.disabled='1' 2>/dev/null || uci delete network.wan6 2>/dev/null

uci commit network

# ============================================================
# 禁用 IPv6
# ============================================================
uci set dhcp.lan.dhcpv6='disabled'
uci set dhcp.lan.ra='disabled'
uci set dhcp.lan.ndp='disabled'
uci commit dhcp

/etc/init.d/odhcp6c disable 2>/dev/null
/etc/init.d/odhcpd stop 2>/dev/null
/etc/init.d/odhcpd disable 2>/dev/null

# ============================================================
# Autoupdate — xztxy/luci-app-autoupdate GitHub API 模式
# ============================================================
uci set autoupdate.@login[0].enable='1'
uci set autoupdate.@login[0].github='https://github.com/lqqk7/Tutu_GW'
uci set autoupdate.@login[0].use_github_api='1'
uci set autoupdate.@login[0].source='openwrt'
uci set autoupdate.@login[0].luci_edition='luci'
uci set autoupdate.@login[0].target_board='x86'
uci set autoupdate.@login[0].device_model='x86-64'
uci set autoupdate.@login[0].firmware_suffix='.img.gz'
uci set autoupdate.@login[0].week='7'
uci set autoupdate.@login[0].hour='3'
uci set autoupdate.@login[0].minute='0'
uci commit autoupdate 2>/dev/null

exit 0
