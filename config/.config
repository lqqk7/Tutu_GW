# Tutu_GW — OpenWrt 24.10 x86_64 build configuration
# Generated for R86S, managed via GitHub Actions

# ============================================================
# Target
# ============================================================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ============================================================
# Image
# ============================================================
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# ============================================================
# Network drivers — R86S
# ============================================================
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-mlx4-core=y
CONFIG_PACKAGE_kmod-mlx4-en=y

# ============================================================
# LuCI
# ============================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y

# ============================================================
# Plugins
# ============================================================
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-advancedplus=y
CONFIG_PACKAGE_luci-app-autoupdate=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-upnp=y

# UPnP: nftables backend (OpenWrt 22.03+ with firewall4)
CONFIG_PACKAGE_miniupnpd-nftables=y
# CONFIG_PACKAGE_miniupnpd is not set

# ============================================================
# OpenClash dependencies
# ============================================================
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_unzip=y

# dnsmasq-full replaces dnsmasq (required by OpenClash for DNS hijack)
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
